# ------------------------------------------------------------------
# Poutou Store — variables d'environnement
# Copiez ce fichier en `.env` puis remplissez les vraies valeurs.
# ------------------------------------------------------------------

# --- Base de données (Supabase > Settings > Database) -------------
# DATABASE_URL : connexion "Transaction pooler" (port 6543) pour l'app
# DIRECT_URL   : connexion directe (port 5432) pour les migrations Prisma
DATABASE_URL="postgresql://postgres.tkjbvqpkuvrdtitiniho:Madiou00siminko@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.tkjbvqpkuvrdtitiniho:Madiou00siminko@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# --- Supabase (Settings > API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://tkjbvqpkuvrdtitiniho.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRramJ2cXBrdXZyZHRpdGluaWhvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMzODAxMTgsImV4cCI6MjA5ODk1NjExOH0.P01tqu6VVr-3Hv7fZgM2-hHvOkCLsV8tMNRa5KstLrc"
# Clé service_role : SERVEUR UNIQUEMENT (upload d'images, seed). Ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRramJ2cXBrdXZyZHRpdGluaWhvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzM4MDExOCwiZXhwIjoyMDk4OTU2MTE4fQ.ktd1EhJPny0r6s7jo8e99Iaw15Bd6oiJUXHLy7LCsek"
# Bucket de stockage des images produits (à créer dans Supabase Storage, en accès public)
SUPABASE_STORAGE_BUCKET="products"

# --- Resend (emails transactionnels + diffusion) --------------------
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
# Expéditeur : utilisez onboarding@resend.dev tant que votre domaine n'est pas vérifié
EMAIL_FROM="Poutou Store <onboarding@resend.dev>"

# --- Boutique --------------------------------------------------------
# Numéro WhatsApp du vendeur, format international SANS "+" ni espaces (ex: 224620000000)
NEXT_PUBLIC_WHATSAPP_PHONE="224XXXXXXXXX"
# Numéro Orange Money affiché au client pour le paiement manuel
NEXT_PUBLIC_ORANGE_MONEY_NUMBER="+224 6XX XX XX XX"
# Devise ISO 4217 (GNF = franc guinéen)
NEXT_PUBLIC_CURRENCY="GNF"
# URL publique du site (redirections d'e-mails d'auth, liens dans les e-mails)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Seed (facultatif) ----------------------------------------------
# E-mail du compte admin créé par `npm run db:seed`
ADMIN_EMAIL="admin@poutou.shop"
# Si renseigné ET que SUPABASE_SERVICE_ROLE_KEY est présent, le seed crée aussi
# le compte Supabase Auth correspondant avec ce mot de passe.
ADMIN_PASSWORD=""
